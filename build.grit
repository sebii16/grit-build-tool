FILES = "src/main.zig"
OUT = "grit"
DEBUG_FLAGS = "-O Debug -freference-trace=10 -lc"
RELEASE_FLAGS = "-O ReleaseSmall -fstrip -lc"

clean {
  "rm -f $OUT"
}

@default
debug {
  'zig build-exe $FILES -femit-bin=$OUT-d.exe $DEBUG_FLAGS'
}

release {
  'zig build-exe $FILES -femit-bin=$OUT.exe $RELEASE_FLAGS'
}

install {
  "copy $OUT.exe c:\grit"
  "copy LICENSE c:\grit"
}

syntax {
 "aaaaaaaa $ERROR1"
}

test {
  "echo $builtin_date"
}
